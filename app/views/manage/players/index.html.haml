.page-block
  .web-header= render 'layouts/left_nav', league: nil
  .web-header= render 'layouts/manage_nav'
  .mob-header= render 'layouts/mob_header', league: nil, title: t('manage.players.title')
  .page-info.admin-manage-page
    %h2= t('manage.players.title')

    - if flash[:notice]
      .alert.alert-success= flash[:notice]
    - if flash[:alert]
      .alert.alert-danger= flash[:alert]

    = form_tag manage_players_path, method: :get, class: 'd-flex flex-wrap gap-2 mb-3' do
      = text_field_tag :name, params[:name], class: 'form-control form-control-sm w-auto', placeholder: t('manage.players.filter_name')
      = text_field_tag :id, params[:id], class: 'form-control form-control-sm w-auto', placeholder: 'ID'
      = text_field_tag :tm_id, params[:tm_id], class: 'form-control form-control-sm w-auto', placeholder: 'TM ID'
      = text_field_tag :fotmob_id, params[:fotmob_id], class: 'form-control form-control-sm w-auto', placeholder: 'Fotmob ID'
      = select_tag :club_id, options_for_select([['— All clubs —', '']] + @clubs.map { |c| [c.name, c.id] }, params[:club_id]),
                   class: 'form-control form-control-sm w-auto'
      = submit_tag t('manage.players.search'), class: 'btn btn-sm btn-primary'
      - if params.slice(:name, :id, :tm_id, :fotmob_id, :club_id).values.any?(&:present?)
        = link_to t('manage.players.reset'), manage_players_path, class: 'btn btn-sm btn-outline-secondary'

    - if @players.any?
      %table.table.table-hover.table-sm
        %thead.thead-light
          %tr
            %th ID
            %th= t('manage.players.col_name')
            %th= t('manage.players.col_first_name')
            %th= t('manage.players.col_club')
            %th TM ID
            %th Fotmob ID
            %th
        %tbody
          - @players.each do |player|
            %tr
              %td= player.id
              %td= link_to player.name, manage_player_path(player)
              %td= player.first_name
              %td= player.club ? link_to(player.club.name, manage_club_path(player.club)) : '—'
              %td= player.tm_id
              %td= player.fotmob_id
              %td= link_to t('manage.players.view'), manage_player_path(player), class: 'btn btn-sm btn-outline-primary'

      = paginate @players
    - else
      %p.text-muted= t('manage.players.empty')

    %button.btn.btn-primary.mt-3#add-player-btn= t('manage.players.add_player')

#add-player-modal.join-modal{ style: 'display:none' }
  .join-modal-content
    .join-modal-header
      %h4= t('manage.players.add_player')
      %button.join-modal-close{ type: 'button' } ×
    = form_tag manage_players_path, method: :post do
      .join-modal-input-field
        %label.join-modal-input-label{ for: 'player_hash' }= t('manage.players.hash_label')
        %textarea#player-hash-input.join-modal-input{ name: 'player_hash', rows: 8, placeholder: t('manage.players.hash_placeholder'), required: true }
      .join-modal-footer
        %button.grey-btn{ type: 'button', id: 'add-player-cancel' }= t('manage.players.cancel')
        %button.blue-btn{ type: 'submit' }= t('manage.players.create')

:javascript
  (function() {
    var modal     = document.getElementById('add-player-modal');
    var openBtn   = document.getElementById('add-player-btn');
    var closeBtn  = modal.querySelector('.join-modal-close');
    var cancelBtn = document.getElementById('add-player-cancel');

    openBtn.onclick  = function() { modal.style.display = 'flex'; };
    closeBtn.onclick = function() { modal.style.display = 'none'; };
    cancelBtn.onclick = function() { modal.style.display = 'none'; };

    modal.addEventListener('click', function(e) {
      if (e.target === modal) modal.style.display = 'none';
    });
  })();