.page-block
  .web-header= render 'layouts/left_nav', league: nil
  .web-header= render 'layouts/manage_nav'
  .mob-header= render 'layouts/mob_header', league: nil, title: @user.name.presence || @user.email
  .page-info.admin-manage-page
    = link_to t('manage.users.back'), manage_users_path, class: 'btn btn-sm btn-outline-secondary mb-3'

    %h2= @user.name.presence || @user.email
    = link_to t('manage.users.view_manager'), manager_path(@user), class: 'btn btn-sm btn-outline-primary mb-3', target: '_blank'

    .row
      .col-md-6
        %h5= t('manage.users.section_account')
        %table.table.table-sm
          %tbody
            %tr
              %th= t('manage.users.email')
              %td= @user.email
            %tr
              %th= t('manage.users.role')
              %td= @user.role
            %tr
              %th= t('manage.users.status')
              %td= @user.status
            %tr
              %th= t('manage.users.created_at')
              %td= local_time(@user.created_at, '%d %b %Y')
            %tr
              %th= t('manage.users.last_sign_in')
              %td= @user.last_sign_in_at ? local_time(@user.last_sign_in_at, '%d %b %Y, %H:%M') : '—'
            %tr
              %th= t('manage.users.sign_in_count')
              %td= @user.sign_in_count
            %tr
              %th= t('manage.users.locale')
              %td= @user.locale
            %tr
              %th= t('manage.users.confirmed')
              %td= @user.confirmed_at ? local_time(@user.confirmed_at, '%d %b %Y') : tag.span(t('manage.users.not_confirmed'), class: 'text-danger')
            %tr
              %th= t('manage.users.champion_number')
              %td= @user.champion_number.present? ? "##{@user.champion_number}" : '—'

      .col-md-6
        %h5= t('manage.users.section_telegram')
        - profile = @user.user_profile
        - if profile
          %table.table.table-sm
            %tbody
              %tr
                %th= t('manage.users.tg_bot')
                %td
                  - if profile.bot_enabled
                    %span.text-success= t('manage.users.yes')
                  - else
                    %span.text-muted= t('manage.users.no')
              %tr
                %th= t('manage.users.tg_name')
                %td= profile.tg_name.presence || '—'
              %tr
                %th= t('manage.users.tg_chat_id')
                %td= profile.tg_chat_id || '—'
        - else
          %p.text-muted= t('manage.users.no_profile')

    %h5.mt-4= t('manage.users.section_teams')
    - if @user.teams.any?
      %table.table.table-hover.table-sm
        %thead.thead-light
          %tr
            %th ID
            %th= t('manage.users.team_name')
            %th= t('manage.users.team_tournament')
            %th= t('manage.users.team_league')
        %tbody
          - @user.teams.each do |team|
            %tr
              %td= team.id
              %td
                = image_tag(team.logo_path, width: 20, height: 20)
                = link_to team.human_name, team_path(team)
              %td
                - if team.tournament
                  = image_tag(team.tournament.logo_path, width: 20, height: 20)
                  = team.tournament.name
                - else
                  %span.text-muted= '—'
              %td= team.league ? link_to(team.league.name, league_path(team.league)) : '—'
    - else
      %p.text-muted= t('manage.users.no_teams')

    %h5.mt-4= t('manage.users.section_titles')
    - if @user.user_titles.any?
      %table.table.table-sm
        %thead.thead-light
          %tr
            %th #
            %th= t('manage.users.title_league')
            %th= t('manage.users.title_tournament')
            %th= t('manage.users.title_season')
            %th= t('manage.users.title_number')
        %tbody
          - @user.user_titles.order(:championship_number).each_with_index do |title, i|
            %tr
              %td= i + 1
              %td
                - if title.result&.league
                  = link_to title.result.league.name, manage_league_path(title.result.league)
                - else
                  %span.text-muted= '—'
              %td
                - if title.tournament
                  = image_tag(title.tournament.logo_path, width: 20, height: 20)
                  = title.tournament.name
                - else
                  %span.text-muted= '—'
              %td= title.season.presence || '—'
              %td= "##{title.championship_number}"
    - else
      %p.text-muted= t('manage.users.no_titles')

    %h5.mt-4= t('manage.users.section_results')
    - if @results.any?
      %table.table.table-hover.table-sm
        %thead.thead-light
          %tr
            %th= t('manage.users.result_team')
            %th= t('manage.users.result_league')
            %th= t('manage.users.result_tournament')
            %th= t('manage.users.result_season')
            %th= t('manage.users.result_points')
            %th= t('manage.users.result_total_score')
            %th= t('manage.users.result_position')
        %tbody
          - @results.each do |result|
            %tr
              %td= link_to result.team.human_name, team_path(result.team)
              %td= result.league ? link_to(result.league.name, manage_league_path(result.league)) : '—'
              %td
                - if result.team.tournament
                  = image_tag(result.team.tournament.logo_path, width: 20, height: 20)
                  = result.team.tournament.name
                - else
                  %span.text-muted= '—'
              %td= result.league&.season&.then { |s| "#{s.start_year}/#{s.end_year}" } || '—'
              %td= result.points
              %td= result.total_score
              %td= result.position.present? ? result.position : '—'
    - else
      %p.text-muted= t('manage.users.no_results')
