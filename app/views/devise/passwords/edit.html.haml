.login-page
  .login-icon
    .mantra-logo
      = link_to root_path do
        = image_tag('logo.svg')
  .login-block
    .login-title-block
      .title-text= t('.change_password')
    .login-form
      = form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, novalidate: true }) do |f|
        = f.hidden_field :reset_password_token
        .login-input
          .login-label= t('.new_password')
          .login-input-icon= image_tag('icons/login/password.svg')
          .login-input-text
            = f.password_field :password, autofocus: true, autocomplete: 'off', class: 'form-control', id: 'user_password', placeholder: t('.new_password')
        - if @minimum_password_length
          .login-password-note= t('devise.shared.minimum_password_length', count: @minimum_password_length)
        #email-error
          = alert
        .login-input
          .login-label= t('.confirm_new_password')
          .login-input-icon= image_tag('icons/login/password.svg')
          .login-input-text
            = f.password_field :password_confirmation, autocomplete: 'off', class: 'form-control', id: 'user_password_confirmation', placeholder: t('.confirm_new_password')
        %small#password-blank-error{ style: 'display:none' }= t('.password_blank')
        %small#password-mismatch-error{ style: 'display:none' }= t('.password_mismatch')
        .login-btn-form
          = f.submit t('.change_password'), class: 'login-btn blue-btn'

:javascript
  (function() {
    var passwordField      = document.getElementById('user_password');
    var confirmField       = document.getElementById('user_password_confirmation');
    var blankError         = document.getElementById('password-blank-error');
    var mismatchError      = document.getElementById('password-mismatch-error');
    if (!passwordField || !confirmField) return;

    function clearErrors() {
      blankError.style.display    = 'none';
      mismatchError.style.display = 'none';
    }

    passwordField.addEventListener('input', clearErrors);
    confirmField.addEventListener('input', clearErrors);

    passwordField.closest('form').querySelector('[type="submit"]').addEventListener('click', function(e) {
      clearErrors();
      var pwd     = passwordField.value;
      var confirm = confirmField.value;
      if (!pwd || !confirm) {
        e.preventDefault();
        blankError.style.display = 'block';
        (pwd ? confirmField : passwordField).focus();
      } else if (pwd !== confirm) {
        e.preventDefault();
        mismatchError.style.display = 'block';
        confirmField.focus();
      }
    });
  })();
