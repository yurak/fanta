.page-block
  .web-header= render 'layouts/left_nav', league: nil
  .web-header= render 'layouts/manage_nav'
  .mob-header= render 'layouts/mob_header', league: nil, title: t('manage.team_of_week.title')
  .page-info.admin-manage-page
    %h2.mb-3= t('manage.team_of_week.title')

    .card.mb-4
      .card-body
        = form_tag manage_team_of_weeks_path, method: :get do
          .d-flex.gap-4.mb-3
            .form-check
              = radio_button_tag :mode, 'top', @mode != :flop, id: 'mode_top', class: 'form-check-input'
              = label_tag 'mode_top', t('manage.team_of_week.mode_top'), class: 'form-check-label'
            .form-check
              = radio_button_tag :mode, 'flop', @mode == :flop, id: 'mode_flop', class: 'form-check-input'
              = label_tag 'mode_flop', t('manage.team_of_week.mode_flop'), class: 'form-check-label'
          - @rounds.group_by(&:tournament).each do |tournament, t_rounds|
            %h5.mb-1= tournament.name
            .d-flex.flex-wrap.gap-3.mb-3
              - t_rounds.each do |round|
                .form-check
                  = check_box_tag 'round_ids[]', round.id, @selected_ids.include?(round.id), id: "round_#{round.id}", class: 'form-check-input'
                  = label_tag "round_#{round.id}", class: 'form-check-label' do
                    = "#{t('manage.team_of_week.round')} #{round.number}"
                    - if round.deadline
                      %small.text-muted= " (#{round.deadline.strftime('%d.%m')})"
          .mt-3
            = submit_tag t('manage.team_of_week.build'), class: 'btn btn-primary'

    - if @teams
      %h4.mb-3= t('manage.team_of_week.results')
      - best_total = @teams.map { |(_, team)| team.sum { |row| row[:entry]&.dig(:total) || 0 } }.max
      .row.g-3
        - @teams.each do |(mod, team)|
          - mod_total = team.sum { |row| row[:entry]&.dig(:total) || 0 }
          - best = mod_total == best_total && best_total.positive?
          .col-md-6.col-xl-4
            .card.h-100{ class: best ? 'border-success border-2' : nil }
              .card-header{ class: best ? 'bg-success text-white' : nil }
                %strong= mod.name
              .card-body.p-0
                %table.table.table-sm.mb-0
                  %thead
                    %tr
                      %th= t('manage.team_of_week.col_position')
                      %th= t('manage.team_of_week.col_player')
                      %th.text-end= t('manage.team_of_week.col_score')
                  %tbody
                    - team.each do |row|
                      %tr
                        %td
                          %code= row[:slot].position
                        - if row[:entry]
                          - club = row[:entry][:player].club
                          %td
                            = row[:entry][:player].full_name
                            - if club
                              %small.text-muted.ms-1= "#{club.tournament&.icon} #{club.name}"
                          %td.text-end= '%.2f' % row[:entry][:total]
                        - else
                          %td.text-muted —
                          %td —
                  %tfoot
                    %tr.table-light
                      %td{colspan: 2}
                        %strong= t('manage.team_of_week.total')
                      %td.text-end
                        %strong= '%.2f' % team.sum { |row| row[:entry]&.dig(:total) || 0 }
