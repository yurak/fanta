- content_for :head do
  %meta{name: "viewport", content: "width=device-width, initial-scale=1"}/
.page-block
  .web-header= render 'layouts/left_nav', league: nil
  .mob-header= render 'layouts/mob_header', league: nil, title: t('join.title')
  .page-info.join-page
    - unless @has_active_leagues || @user_joins.any?
      .join-no-leagues-banner
        .join-no-leagues-icon 🏖️
        %h2.join-no-leagues-title= t('join.no_active_leagues_title')
        %p.join-no-leagues-subtitle= t('join.no_active_leagues_subtitle')
    .join-info-cards{ class: current_user.user_profile&.bot_enabled ? nil : 'join-info-cards-3' }
      .join-info-card
        .join-info-card-title
          %span ⚖️
          = t('join.rules_title')
        = link_to t('join.rules_link'), rules_path, class: 'join-info-card-link'
      - unless current_user.user_profile&.bot_enabled
        .join-info-card
          .join-info-card-title
            %span ✈️
            = t('join.telegram_title')
          = link_to '#', data: { connect_url: telegram_connect_user_path(current_user) }, class: 'join-tg-connect-btn join-info-card-link' do
            = image_tag 'icons/telegram.svg', class: 'join-info-card-icon'
            = t('join.telegram_link')
      .join-info-card
        .join-info-card-title
          %span 🧩
          = t('join.contact_title')
        = link_to 'https://t.me/mantra_help', class: 'join-info-card-link', target: '_blank' do
          = image_tag 'icons/telegram.svg', class: 'join-info-card-icon'
          = t('join.contact_link')
    .join-card
      .join-content-grid
        - if @user_joins.any?
          .join-col
            .join-card-header
              %h2.join-card-title= t('join.my_applications')
            .join-tournaments-list
              - @user_joins.each do |join|
                - bid = join.auction_bid
                = link_to bid ? auction_bid_path(bid) : '#', class: 'join-tournament-item' do
                  .join-tournament-logo
                    = image_tag(join.tournament.logo_path)
                  .join-tournament-info
                    .join-tournament-name= join.tournament.name
                    .join-tournament-meta= join.team.human_name
                  .join-tournament-action
                    .join-status-badge{ class: "join-status-#{join.status}" }= t("join.status.#{join.status}")
        .join-col
          .join-card-header
            %h2.join-card-title= t('join.title')
          - if @tournaments.any?
            .join-tournaments-list
              - @tournaments.each do |tournament|
                - existing_team = @existing_teams[tournament.id]
                .join-tournament-item.join-apply-btn{ data: { tournament_id: tournament.id,
                                                               existing_team_id: existing_team&.id,
                                                               existing_team_name: existing_team&.human_name,
                                                               existing_team_code: existing_team&.code,
                                                               existing_team_logo: existing_team&.logo_path } }
                  .join-tournament-logo
                    = image_tag(tournament.logo_path)
                  .join-tournament-info
                    .join-tournament-name= tournament.name
                    .join-tournament-meta
                      %span= "#{tournament.mode&.capitalize} · #{tournament.active_teams_count} #{t('join.teams')}"
                      %span.join-tournament-meta-apps
                        %span.join-tournament-meta-sep ·&nbsp;
                        = "#{tournament.joins_count} #{t('join.applications')}"
                  .join-tournament-action
                    %span.join-apply-text
                      = t('join.apply')
                      %span.join-apply-arrow ›
          - else
            .join-empty= t('join.no_leagues')

= render 'joins/team_modal'

- unless current_user.user_profile&.bot_enabled
  :javascript
    (function() {
      const btn = document.querySelector('.join-tg-connect-btn');
      if (!btn) return;

      btn.addEventListener('click', function(e) {
        e.preventDefault();
        fetch(btn.dataset.connectUrl, {
          method: 'POST',
          headers: { 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          window.open(data.url, '_blank');
        });
      });
    })();
