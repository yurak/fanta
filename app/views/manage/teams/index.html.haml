.page-block
  .web-header= render 'layouts/left_nav', league: nil
  .web-header= render 'layouts/manage_nav'
  .mob-header= render 'layouts/mob_header', league: nil, title: t('manage.teams.title')
  .page-info.admin-manage-page
    %h2= t('manage.teams.title')

    = form_tag manage_teams_path, method: :get, class: 'd-flex gap-2 mb-3' do
      = text_field_tag :name, params[:name], class: 'form-control form-control-sm w-auto', placeholder: t('manage.teams.filter_name')
      = submit_tag t('manage.teams.search'), class: 'btn btn-sm btn-primary'
      - if params[:name].present?
        = link_to t('manage.teams.reset'), manage_teams_path, class: 'btn btn-sm btn-outline-secondary'

    - if @teams.any?
      %table.table.table-hover.table-sm
        %thead.thead-light
          %tr
            %th ID
            %th= t('manage.teams.name')
            %th= t('manage.teams.tournament')
            %th= t('manage.teams.league')
            %th= t('manage.teams.user')
        %tbody
          - @teams.each do |team|
            %tr
              %td= team.id
              %td
                = image_tag(team.logo_path, width: 20, height: 20)
                = link_to team.human_name, team_path(team)
              %td= team.tournament&.name || '—'
              %td= team.league ? link_to(team.league.name, league_path(team.league)) : '—'
              %td= team.user ? link_to(team.user.name.presence || team.user.email, manage_user_path(team.user)) : '—'

      = paginate @teams
    - else
      %p.text-muted= t('manage.teams.empty')
