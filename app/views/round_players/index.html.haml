.page-block
  .web-header= render 'layouts/left_nav', league: nil
  - if league
    .web-header= render 'layouts/right_nav', league: league
  .mob-header= render 'layouts/mob_header', league: nil, title: t('round_players.short_title')
  = react_component("App")
  - if league
    .portrait-footer{ class: "portrait-footer-#{league.mantra?}" }
      = render 'layouts/league_links', league: league
